APP_NAME="Verve News Network"
APP_SHORTNAME=VNN
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://vervenews.ng

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_NG

APP_TAGLINE="Nigeria's Most Trusted News Source"
APP_TIMEZONE=Africa/Lagos

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=warning

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=vnn
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=.vervenews.ng

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=public
QUEUE_CONNECTION=redis

CACHE_STORE=redis
CACHE_PREFIX=vnn_

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_SCHEME=null
MAIL_HOST=smtp.sendgrid.net
MAIL_PORT=587
MAIL_USERNAME=apikey
MAIL_PASSWORD=
MAIL_FROM_ADDRESS="noreply@vervenews.ng"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=af-south-1
AWS_BUCKET=vnn-assets
AWS_USE_PATH_STYLE_ENDPOINT=false

MEDIA_DISK=s3
MEDIA_PATH=media

RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=

NEWSAPI_KEY=
NEWSAPI_BASE_URL=https://newsapi.org/v2

VITE_APP_NAME="${APP_NAME}"
VITE_APP_URL="${APP_URL}"
